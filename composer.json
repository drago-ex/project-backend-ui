{
	"name": "drago-ex/project-backend-ui",
	"type": "project",
	"description": "Integration of a basic template for administration.",
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/project-user": "^1.0",
		"drago-ex/project-backend": "^1.0",
		"drago-ex/project-auth": "^1.0"
	},
	"extra": {
		"drago-project": {
			"allow-library-install": true,
			"install": {
				"copy": {
					"resources/assets": "assets"
				},
				"replace": {
					"resources/app": "app"
				}
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^1.2.9",
		"drago-ex/project-installer": "@dev"
	},
	"scripts": {
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
