{
	"name": "drago-ex/project-backend-ui",
	"type": "project",
	"description": "Integration of a basic template for administration.",
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/project-user": "^2.0",
		"drago-ex/project-backend": "^2.0",
		"drago-ex/project-auth": "^2.0"
	},
	"suggest": {
		"drago-ex/translator": "Configures Latte translation support for bundled templates using translation macros."
	},
	"extra": {
		"drago-project": {
			"allow-library-install": true,
			"priority": 200,
			"install": {
				"copy": {
					"resources/assets": "assets"
				},
				"replace": {
					"resources/app": "app"
				}
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan": "^2.0",
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-installer": "@dev"
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
